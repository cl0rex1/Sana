# =========================
# Sana - Environment Example
# Copy this file to .env in project root
# =========================

# Server
NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:5173
MONGO_URI=mongodb://localhost:27017/sana
JWT_SECRET=change_me_super_secret_jwt_key

# OpenRouter (AI) / Self-Hosted AI
# Required for AI-generated facts/scenarios and AI moderation.
# Default endpoint is OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_SCENARIO_MODEL=google/gemini-2.5-flash
OPENROUTER_SCENARIO_BACKUP_MODEL=google/gemini-2.0-flash-001

# Self-Hosting (Optional)
# If using Ollama/LocalAI, set the local endpoint and model name.
# AI_API_URL=http://localhost:11434/v1/chat/completions
# AI_API_KEY=ollama (or any non-empty string)
# OPENROUTER_MODEL=llama3 (example for Ollama)

# Client (Vite)
# Optional. Keep in sync with API server port.
VITE_API_TARGET=http://localhost:5001
